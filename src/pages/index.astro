---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Niklas Jütting">
  <main>
    <section class="hero">
      <div class="container hero-grid">

        <div class="hero-photo-wrap">
          <img src={`${base}/photo.jpg`} alt="Niklas Jütting" class="hero-photo" />
        </div>

        <div class="hero-text">
          <h1>Niklas Jütting</h1>
          <p class="hero-subtitle">International Economic Policy · Paris</p>

          <div class="bio">
            <p>
              I'm an economist and analyst interested in how geopolitical forces shape
              macroeconomic outcomes. My research sits at the intersection of
              international trade, economic security, and the politics of globalisation —
              in particular, how great-power competition and shifting alliances are
              redrawing the map of global economic integration.
            </p>
            <p>
              I'm currently completing a Master's in International Economic Policy at
              Sciences Po Paris. Before that I studied at University College London, and
              I've had the opportunity to work at the <strong>European Central Bank</strong> and
              the <strong>OECD</strong>, where I got hands-on experience in policy analysis,
              institutional briefing, and applied research.
            </p>
            <p>
              I'm particularly drawn to questions about trade fragmentation,
              geoeconomic risk, and the long-run consequences of economic decoupling —
              topics that feel increasingly urgent but are still underexplored in the
              academic literature.
            </p>
          </div>

          <div class="hero-links">
            <a href="mailto:jutting.n@gmail.com" class="hero-link">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
              jutting.n@gmail.com
            </a>
            <a href="https://www.linkedin.com/in/niklas-jutting-676147225/" target="_blank" rel="noopener noreferrer" class="hero-link">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/>
              </svg>
              LinkedIn
            </a>
          </div>
        </div>

      </div>
    </section>
  </main>
</Layout>

<style>
  .hero {
    padding: 5rem 0;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 4rem;
    align-items: flex-start;
  }

  .hero-photo-wrap {
    position: sticky;
    top: calc(var(--nav-height) + 2rem);
  }

  .hero-photo {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    object-position: center top;
    border-radius: 10px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    display: block;
  }

  h1 {
    font-size: 1.75rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 0.35rem;
  }

  .hero-subtitle {
    font-size: 0.875rem;
    color: var(--accent);
    font-weight: 500;
    margin-bottom: 1.75rem;
  }

  .bio {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .bio p {
    font-size: 0.975rem;
    color: var(--text-muted);
    line-height: 1.8;
  }

  .bio strong {
    color: var(--text);
    font-weight: 500;
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .hero-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-muted);
    transition: color 0.15s;
  }

  .hero-link:hover {
    color: var(--accent);
  }

  @media (max-width: 680px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .hero-photo-wrap {
      position: static;
      max-width: 140px;
    }

    .hero-photo {
      border-radius: 50%;
    }

    .hero {
      padding: 3rem 0;
    }
  }
</style>
