---
import Nav from '../components/Nav.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Niklas Jütting — International Economic Policy" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <Nav />
    <slot />
    <footer>
      <div class="container footer-inner">
        <span>© {new Date().getFullYear()} Niklas Jütting</span>
        <a href="mailto:jutting.n@gmail.com">jutting.n@gmail.com</a>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --bg: #F9F8F5;
    --white: #FFFFFF;
    --text: #161616;
    --text-muted: #5C5C5C;
    --accent: #1740CC;
    --accent-hover: #1234A8;
    --border: #E4E3DD;
    --tag-bg: #EEEDE8;
    --nav-height: 60px;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    background-color: var(--bg);
    color: var(--text);
    line-height: 1.65;
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  ul {
    list-style: none;
  }

  .container {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  footer {
    padding: 2rem 0;
    border-top: 1px solid var(--border);
    margin-top: 4rem;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .footer-inner a:hover {
    color: var(--text);
  }

  @media (max-width: 640px) {
    .container {
      padding: 0 1.25rem;
    }
  }
</style>
