---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const pathname = Astro.url.pathname.replace(/\/$/, '');

const navItems = [
  { label: 'Home',     href: base || '/' },
  { label: 'Research', href: `${base}/research` },
  { label: 'CV',       href: `${base}/cv` },
  { label: 'Contact',  href: `${base}/contact` },
];

function isActive(href: string): boolean {
  const h = href.replace(/\/$/, '');
  if (h === base || h === '') {
    return pathname === base || pathname === '' || pathname === '/';
  }
  return pathname === h || pathname.startsWith(h + '/');
}
---

<nav>
  <div class="container nav-inner">
    <a href={`${base}/`} class="nav-name">Niklas Jütting</a>
    <ul class="nav-links">
      {navItems.map(item => (
        <li>
          <a href={item.href} class:list={['nav-link', { active: isActive(item.href) }]}>
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(249, 248, 245, 0.93);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
    height: var(--nav-height);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  .nav-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.01em;
    transition: color 0.15s;
  }

  .nav-name:hover {
    color: var(--accent);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
    list-style: none;
  }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-muted);
    transition: color 0.15s;
  }

  .nav-link:hover {
    color: var(--text);
  }

  .nav-link.active {
    color: var(--accent);
  }

  @media (max-width: 480px) {
    .nav-links {
      gap: 1.25rem;
    }
  }
</style>
